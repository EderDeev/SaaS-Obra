APP_NAME="Deming"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-app.up.railway.app
APP_ROOT_DOMAIN=
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_URL=${{Postgres.DATABASE_URL}}
# Se voce usar DATABASE_URL direto pelo Railway, o app tambem consegue ler.
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
# Use database para processar imports grandes e tarefas APS fora da requisicao HTTP.
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=3900
BROADCAST_CONNECTION=log

FILESYSTEM_DISK=public
# Crie um Railway Volume no servico da aplicacao com mount path:
# /app/storage/app/public
# O Railway injeta RAILWAY_VOLUME_MOUNT_PATH automaticamente em runtime.

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo SMTP para testar emails reais:
# MAIL_MAILER=smtp
# Remova MAIL_SCHEME ou use MAIL_SCHEME=smtp. O valor literal "null" tambem
# e tratado como ausente pela aplicacao para compatibilidade com o Railway.
# MAIL_SCHEME=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=seu-login-smtp-brevo
# MAIL_PASSWORD=sua-chave-smtp-brevo
# MAIL_TIMEOUT=30
# MAIL_FROM_ADDRESS="email-verificado@seudominio.com"
# MAIL_FROM_NAME="${APP_NAME}"

AUTODESK_APS_CLIENT_ID=
AUTODESK_APS_CLIENT_SECRET=
AUTODESK_APS_BUCKET_KEY=
AUTODESK_APS_REGION=US
AUTODESK_APS_STORAGE_LIMIT_BYTES=5368709120
AUTODESK_APS_SCOPES="data:read data:write data:create bucket:create bucket:read viewables:read"
AUTODESK_APS_VERIFY_SSL=true
AUTODESK_APS_CA_BUNDLE=
AUTODESK_APS_AUTO_PROCESS=true

GED_OCR_ENABLED=true
GED_OCR_QUEUE=ged
GED_OCR_LANGUAGE=por+eng
GED_OCR_MODE=skip
GED_OCR_OUTPUT_TYPE=pdf
GED_OCR_DESKEW=false
GED_OCR_ROTATE_PAGES=false
GED_OCR_MAX_PAGES=10
GED_OCR_TIMEOUT=600
GED_OCR_OCRMYPDF_BIN=ocrmypdf
GED_OCR_PDFTOTEXT_BIN=pdftotext
GED_OCR_PDFINFO_BIN=pdfinfo

VITE_APP_NAME="${APP_NAME}"
VITE_MAPBOX_ACCESS_TOKEN=

# Ative somente no primeiro deploy de teste se quiser criar os usuarios demo.
RAILWAY_RUN_SEEDER=false
RAILPACK_PHP_ROOT_DIR=/app/public
RAILPACK_PHP_VERSION=8.4
NIXPACKS_PHP_ROOT_DIR=/app/public
